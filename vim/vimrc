    set guifont=JetBrainsMono\ Nerd\ Font:h12
  elseif has('mac')
    set guifont=Menlo:h12
  elseif has('win32') || has('win64')
    set guifont=Consolas:h11
  endif
endif

" OPTIONS:
filetype plugin on
filetype indent on
syntax enable
syntax on
set autoread
set backspace=indent,eol,start
set ruler
set number
set relativenumber
set showmode
set cursorline
set colorcolumn=80
set clipboard^=unnamed,unnamedplus
set nowrap
set showtabline=2
set laststatus=2
set wildmenu
set wildmode=longest:full,full
set autoindent
set cindent
set smartindent
set expandtab
set tabstop=2
set shiftwidth=2
set softtabstop=2
set smarttab
set hlsearch
set incsearch
set ignorecase
set smartcase
set nobackup
set noswapfile
set timeoutlen=500
set ttimeoutlen=500

