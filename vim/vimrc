Plug 'vim-test/vim-test', { 'on': ['TestNearest', 'TestFile', 'TestSuite', 'TestLast', 'TestVisit'] }

if has('python3')
  Plug 'puremourning/vimspector', { 'on': ['VimspectorInstall', '<Plug>VimspectorContinue', '<Plug>VimspectorBreakpoints', '<Plug>VimspectorToggleBreakpoint', '<Plug>VimspectorGoToCurrentLine'] }
  Plug 'vim-autoformat/vim-autoformat', { 'on': ['Autoformat'] }
endif

Plug 'liuchengxu/vim-which-key', { 'on': ['WhichKey', 'WhichKey!'] }
nnoremap <silent> <Leader> :<C-u>WhichKey '<Space>'<CR>
nnoremap <silent> <Localleader> :<C-u>WhichKey ','<CR>
augroup load_vim_which_key
  let g:which_key_map = {}
  let g:which_key_map['c'] = {
        \ 'name': '+Config',
        \ 'e': ['<Leader>ce', 'Edit'],
        \ 'r': ['<Leader>cr', 'Reload'],
        \ }
  let g:which_key_map['w'] = {
        \ 'name': '+Window',
        \ 'o': ['<Leader>wo', '<Plug>choosewin'],
        \ }
  let g:which_key_map['f'] = {
        \ 'name': '+Find',
        \ 'b': ['<Leader>fb', 'Buffers'],
        \ 'c': ['<Leader>fc', 'Colorschemes'],
        \ 'f': ['<Leader>ff', 'Files'],
        \ 'F': ['<Leader>ff', 'Files in root'],
        \ 's': ['<Leader>fs', 'Buffer Words'],
        \ 'w': ['<Leader>fw', 'Words'],
        \ 'r': ['<Leader>fr', 'Recent Files'],
        \ }
  let g:which_key_map['t'] = {
        \ 'name': '+Toggle',
        \ 'g': ['<Leader>tg', 'Goyo'],
        \ 'r': ['<Leader>tr', 'Run Code'],
        \ 'v': ['<Leader>tv', 'Code Outline'],
        \ 'u': ['<Leader>tu', 'Undo Tree'],
        \ 't': ['<Leader>tt', 'Startup Time'],
        \ }
  autocmd! User vim-which-key call which_key#register('<Space>', 'g:which_key_map', 'n')
augroup end

call plug#end()
